# Copie para .env.local e preencha. Em produção use também .env.production no servidor.

# Obrigatório em produção: assinatura do cookie de sessão
SESSION_SECRET=

# Senha de acesso (primeiro login ou utilizadores criados só via app)
APP_PASSWORD=

# Opcional: se definido, o email no login deve coincidir ao usar APP_PASSWORD
# APP_EMAIL=

# Chaves de API (servidor). Em dev pode usar Definições → Chaves; em produção use o .env.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

GROQ_API_KEY=
